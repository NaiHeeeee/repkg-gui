{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "repkg-gui",
  "version": "0.6.11",
  "identifier": "com.naihe.repkg-gui",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "repkg-gui",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DATA/repkg-gui/backgrounds/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "./bin/*"
    ],
    "publisher": "NaiHe",
    "copyright": "Copyright © 2024-2026 NaiHe",
    "category": "Utility",
    "shortDescription": "RePKG 图形化管理工具",
    "longDescription": "repkg-gui 是一款用于 Wallpaper Engine 壁纸资源包解包和管理的图形化工具。",
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "languages": [
          "SimpChinese",
          "English",
          "TradChinese",
          "Japanese"
        ],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/windows.nsh",
        "startMenuFolder": "repkg-gui"
      }
    }
  }
}